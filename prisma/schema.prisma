// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      String   @default("user")
  emailVerified DateTime?
  verificationTokenHash String?
  verificationTokenExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessments      Assessment[]
  savedLaws        SavedLaw[]
  alertPreferences AlertPreference[]
  orgMemberships   OrganizationMember[]
  assignedItems    ChecklistItem[]     @relation("Assignee")

  // WS1: Provenance — laws this user verified
  verifiedLaws     Law[]               @relation("LawVerifier")

  // WS2: Editorial Workflow
  auditLogEntries  ContentEditAuditLog[] @relation("AuditLogActor")
  reviewRequests   ContentApproval[]     @relation("ContentReviewer")
  approvalDecisions ContentApproval[]   @relation("ContentApprover")

  @@map("users")
}

model Law {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  shortTitle     String?
  jurisdiction   String?
  topics         String?
  issuingBody    String?
  status         String?
  contentType    String?
  summaryShort   String?
  summaryLong    String?
  officialUrl    String?
  adoptedDate    DateTime?
  effectiveDate  DateTime?
  lastReviewedAt DateTime?
  isPublished    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // WS1: Legal Provenance
  sourceKind         String?   // primary_law | regulator_guidance | standard | proposal | policy | editorial_summary
  sourceAuthority    String?
  sourceJurisdiction String?
  sourceCitationFull String?
  verifiedAt         DateTime?
  verifiedByUserId   String?
  verifiedBy         User?     @relation("LawVerifier", fields: [verifiedByUserId], references: [id])
  confidenceLevel    String    @default("medium") // high | medium | low
  reviewStatus       String    @default("needs_review") // draft | needs_review | verified | superseded | archived
  supersededById     String?
  editorNotes        String?
  rulesEngineVersion String?

  // WS8: Source Health
  sourceHealthStatus String?   // ok | redirect | broken | archived | unknown
  sourceCheckedAt    DateTime?
  sourceArchiveUrl   String?

  obligations        Obligation[]
  applicabilityRules ApplicabilityRule[]
  savedBy            SavedLaw[]
  changelog          LawChangelog[]
  assessmentResults  AssessmentResult[]
  editAuditLogs      ContentEditAuditLog[]
  sourceHealthChecks SourceHealthCheck[]

  @@index([jurisdiction])
  @@index([reviewStatus])
  @@index([sourceHealthStatus])
  @@index([isPublished])
  @@map("laws")
}

model Obligation {
  id             String   @id @default(cuid())
  lawId          String
  law            Law      @relation(fields: [lawId], references: [id])
  title          String
  description    String?
  category       String?
  priority       String?
  citation       String?
  actionRequired String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // WS1: Provenance
  sourceKind         String?
  sourceCitationFull String?
  sourceExcerpt      String?
  confidenceLevel    String    @default("medium")
  reviewStatus       String    @default("draft")
  changeReason       String?
  editorNotes        String?
  verifiedAt         DateTime?

  checklistItems ChecklistItem[]
  editAuditLogs  ContentEditAuditLog[]

  @@index([lawId])
  @@index([reviewStatus])
  @@map("obligations")
}

model ApplicabilityRule {
  id       String  @id @default(cuid())
  lawId    String
  law      Law     @relation(fields: [lawId], references: [id])
  name     String?
  ruleJson String
  weight   Float   @default(1)
  enabled  Boolean @default(true)

  @@map("applicability_rules")
}

model Assessment {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  name             String?
  companyProfile   String
  productProfile   String
  technicalProfile String
  reviewStatus     String   @default("draft")
  createdAt        DateTime @default(now())

  results    AssessmentResult[]
  checklists Checklist[]

  @@index([userId])
  @@map("assessments")
}

model AssessmentResult {
  id                  String     @id @default(cuid())
  assessmentId        String
  assessment          Assessment @relation(fields: [assessmentId], references: [id])
  lawId               String?
  law                 Law?       @relation(fields: [lawId], references: [id])
  lawSlug             String
  relevanceScore      Float?
  applicabilityStatus String?
  rationale           String?
  createdAt           DateTime   @default(now())

  // WS3: Rules Engine Explainability
  rulesEngineVersion String?
  evaluationTrace    String? // JSON: { matchedRules, missedRules, score, weightBreakdown }

  @@index([assessmentId])
  @@index([lawSlug])
  @@map("assessment_results")
}

model Checklist {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  title        String?
  createdAt    DateTime   @default(now())

  items ChecklistItem[]

  @@map("checklists")
}

model ChecklistItem {
  id           String      @id @default(cuid())
  checklistId  String
  checklist    Checklist   @relation(fields: [checklistId], references: [id])
  obligationId String?
  obligation   Obligation? @relation(fields: [obligationId], references: [id])
  lawSlug      String?
  title        String
  description  String?
  category     String?
  citation     String?
  status       String      @default("not_started")
  priority     String?
  assigneeId   String?
  assignee     User?       @relation("Assignee", fields: [assigneeId], references: [id])
  dueDate      DateTime?
  updatedAt    DateTime    @updatedAt
  createdAt    DateTime    @default(now())

  @@map("checklist_items")
}

model SavedLaw {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  lawSlug   String
  law       Law      @relation(fields: [lawSlug], references: [slug])
  createdAt DateTime @default(now())

  @@unique([userId, lawSlug])
  @@map("saved_laws")
}

model LawChangelog {
  id         String   @id @default(cuid())
  lawSlug    String
  law        Law      @relation(fields: [lawSlug], references: [slug])
  changeType String
  summary    String
  details    String?
  changedAt  DateTime @default(now())

  // WS2: Editorial Governance
  actorId               String?
  actorName             String?
  changeReason          String?
  isCorrectionNotUpdate Boolean @default(false)

  @@map("law_changelog")
}

// WS2: Content Edit Audit Log — every law/obligation field change
model ContentEditAuditLog {
  id           String   @id @default(cuid())
  entityType   String   // law | obligation
  entityId     String
  lawId        String?
  law          Law?     @relation(fields: [lawId], references: [id])
  obligationId String?
  obligation   Obligation? @relation(fields: [obligationId], references: [id])
  actorId      String
  actor        User     @relation("AuditLogActor", fields: [actorId], references: [id])
  fieldName    String
  oldValue     String?
  newValue     String?
  changeReason String?
  createdAt    DateTime @default(now())

  @@index([entityId])
  @@index([actorId])
  @@map("content_edit_audit_logs")
}

// WS2: Content Approval Workflow
model ContentApproval {
  id           String   @id @default(cuid())
  entityType   String   // law | obligation
  entityId     String
  reviewerId   String
  reviewer     User     @relation("ContentReviewer", fields: [reviewerId], references: [id])
  approverId   String?
  approver     User?    @relation("ContentApprover", fields: [approverId], references: [id])
  status       String   @default("pending") // pending | approved | rejected | superseded
  notes        String?
  requestedAt  DateTime @default(now())
  resolvedAt   DateTime?

  @@index([entityId])
  @@map("content_approvals")
}

// WS8: Source Health Checks
model SourceHealthCheck {
  id              String   @id @default(cuid())
  lawId           String
  law             Law      @relation(fields: [lawId], references: [id])
  checkedUrl      String   // The URL that was checked
  status          String   // ok | redirect | broken | timeout | blocked | archived | content_changed | unknown
  httpStatus      Int?
  redirectUrl     String?
  checkedAt       DateTime @default(now())
  errorMessage    String?
  responseTimeMs  Int?

  @@index([lawId])
  @@map("source_health_checks")
}

model AlertPreference {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  lawSlug      String?
  jurisdiction String?
  emailEnabled Boolean  @default(true)
  digestMode   String   @default("immediate")
  createdAt    DateTime @default(now())

  @@map("alert_preferences")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  members OrganizationMember[]
  invites OrganizationInvite[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  role           String       @default("member")
  joinedAt       DateTime     @default(now())

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  token          String       @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@map("organization_invites")
}
